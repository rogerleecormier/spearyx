{
  "name": "spearyx-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "build": "./node_modules/.bin/turbo run build",
    "dev": "./node_modules/.bin/turbo run dev --parallel",
    "lint": "./node_modules/.bin/turbo run lint",
    "test": "./node_modules/.bin/turbo run test",
    "preview": "./node_modules/.bin/turbo run preview",
    "deploy": "./node_modules/.bin/turbo run deploy --concurrency=1",
    "deploy:workers": "pnpm --filter @spearyx/jobs run deploy:workers",
    "sync:local": "node seed-jobs-db-direct.js && npm --prefix apps/jobs run build && npm --prefix apps/jobs run serve"
  },
  "devDependencies": {
    "pnpm": "latest",
    "turbo": "latest",
    "wrangler": "^4.87.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
