    "deploy:remoteok": "wrangler deploy --config wrangler.remoteok.toml",
    "deploy:himalayas": "wrangler deploy --config wrangler.himalayas.toml",
    "deploy:workers": "pnpm run deploy:ats && pnpm run deploy:discovery && pnpm run deploy:jobicy && pnpm run deploy:remoteok && pnpm run deploy:himalayas",
    "deploy": "pnpm run build && wrangler deploy --config wrangler.toml"
